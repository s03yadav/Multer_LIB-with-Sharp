<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Success - Download Image</title>
    <style>
        body {
            font-family: system-ui, -apple-system, sans-serif;
            background-color: #f9fafb;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
        .form-container {
            background-color: #ffffff;
            padding: 2.5rem;
            border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            width: 100%;
            max-width: 400px;
            box-sizing: border-box;
            text-align: center;
        }
        h1 {
            font-size: 1.5rem;
            color: #111827;
            margin-bottom: 1.5rem;
            margin-top: 0;
        }
        .preview-container {
            margin-bottom: 1.5rem;
            border: 1px solid #d1d5db;
            border-radius: 6px;
            padding: 0.5rem;
            background-color: #f3f4f6;
            display: flex;
            justify-content: center;
            align-items: center;
            max-height: 250px;
            overflow: hidden;
        }
        .preview-container img {
            max-width: 100%;
            max-height: 234px;
            border-radius: 4px;
            object-fit: contain;
        }
        .button-group {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }
        /* Primary Action: Download Button */
        .btn-download {
            display: block;
            width: 100%;
            background-color: #10b981;
            color: white;
            padding: 0.75rem;
            border: none;
            border-radius: 6px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: background-color 0.2s;
            box-sizing: border-box;
        }
        .btn-download:hover {
            background-color: #059669;
        }
        /* Secondary Action: Back to Home */
        .btn-home {
            display: block;
            width: 100%;
            background-color: #3b82f6;
            color: white;
            padding: 0.75rem;
            border: none;
            border-radius: 6px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: background-color 0.2s;
            box-sizing: border-box;
        }
        .btn-home:hover {
            background-color: #2563eb;
        }
    </style>
</head>
<body>

    <div class="form-container">
        <h1>Compression Complete!</h1>
        
        <div class="preview-container">
            <!-- Replace the src with your actual compressed image path dynamically -->
            <img src="/compressed/<%= image %>" alt="Compressed Preview">
        </div>
        
        <div class="button-group">
            <!-- Replace the href with your actual image path to trigger download -->
            <a href="/compressed/<%= image %>" download class="btn-download">Download Image</a>
            <a href="/" class="btn-home">Compress Another</a>
        </div>
    </div>

</body>
</html>