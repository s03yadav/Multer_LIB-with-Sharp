<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home - Upload Image</title>
    <style>
        body {
            font-family: system-ui, -apple-system, sans-serif;
            background-color: #f9fafb;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
        .form-container {
            background-color: #ffffff;
            padding: 2.5rem;
            border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            width: 100%;
            max-width: 400px;
        }
        h1 {
            font-size: 1.5rem;
            color: #111827;
            margin-bottom: 1.5rem;
            text-align: center;
        }
        .form-group {
            margin-bottom: 1.5rem;
        }
        label {
            display: block;
            font-weight: 500;
            margin-bottom: 0.5rem;
            color: #374151;
        }
        input[type="file"] {
            display: block;
            width: 100%;
            font-size: 0.875rem;
            color: #6b7280;
            border: 1px solid #d1d5db;
            border-radius: 6px;
            padding: 0.5rem;
            background-color: #f3f4f6;
            cursor: pointer;
        }
        input[type="file"]::file-selector-button {
            background-color: #3b82f6;
            color: white;
            padding: 0.375rem 0.75rem;
            border: none;
            border-radius: 4px;
            font-weight: 500;
            cursor: pointer;
            margin-right: 0.75rem;
        }
        input[type="file"]::file-selector-button:hover {
            background-color: #2563eb;
        }
        button {
            width: 100%;
            background-color: #10b981;
            color: white;
            padding: 0.75rem;
            border: none;
            border-radius: 6px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.2s;
        }
        button:hover {
            background-color: #059669;
        }
    </style>
</head>
<body>

    <div class="form-container">
        <h1>Welcome! Upload Your Image</h1>
        
        <!-- The enctype="multipart/form-data" attribute is required for file uploads to work -->
        <form action="/upload" method="POST" enctype="multipart/form-data">
            <div class="form-group">
                <label for="image-input">Select an image:</label>
                <input 
                    type="file" 
                    id="image-input" 
                    name="imgUpload" 
                    required
                >
            </div>
            
            <button type="submit">Upload Image</button>
        </form>
    </div>

</body>
</html>